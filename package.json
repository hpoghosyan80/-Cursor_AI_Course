{
  "name": "cursor-ai-course-taskflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test:e2e": "playwright test --grep-invert \"Documentation screenshots\"",
    "test:e2e:ci": "PLAYWRIGHT_JSON_OUTPUT_NAME=docs/test-report/results.json playwright test --grep-invert \"Documentation screenshots\" --reporter=html,json && node scripts/generate-test-report.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report docs/test-report/html",
    "screenshots": "playwright test e2e/capture-screenshots.spec.ts --project=chromium"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
