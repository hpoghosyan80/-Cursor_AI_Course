{
  "name": "module-8-qa-automation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test:jest": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --json --outputFile=qa/reports/jest-results.json",
    "test:jest:watch": "jest --config jest.config.js --watch",
    "test:e2e:pom": "playwright test --config qa/framework/playwright.config.ts",
    "test:e2e:pom:ui": "playwright test --config qa/framework/playwright.config.ts --ui",
    "qa:all": "bash qa/run-all-checks.sh",
    "lint:eslint": "eslint --config eslint.config.js --format json --output-file qa/reports/eslint-results.json || true",
    "lint:eslint:check": "eslint --config eslint.config.js",
    "lighthouse": "lighthouse http://localhost:5173 --only-categories=performance,accessibility,best-practices,seo --output=json --output-path=qa/reports/lighthouse-results.json --chrome-flags='--headless --no-sandbox' --quiet || echo '{\"skipped\":true}' > qa/reports/lighthouse-results.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^12.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
